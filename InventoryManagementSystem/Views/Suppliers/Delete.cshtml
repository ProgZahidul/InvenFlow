@model InventoryManagementSystem.Models.Supplier

@{
    ViewData["Title"] = "Delete Supplier";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Delete Supplier</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to List
    </a>
</div>

<div class="alert alert-danger">
    <h4 class="alert-heading">Warning!</h4>
    <p>Are you sure you want to permanently delete this supplier? This action cannot be undone and will remove the supplier from the system.</p>
    <p class="mb-0"><strong>Note:</strong> This action is only allowed if the supplier has no associated purchase orders.</p>
</div>

<div class="card">
    <div class="card-header">
        <h4>Supplier Information</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Name:</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Contact Person:</dt>
            <dd class="col-sm-9">@Model.ContactPerson</dd>

            <dt class="col-sm-3">Phone:</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Email:</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Address:</dt>
            <dd class="col-sm-9">@Model.Address</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group mt-3">
        <button type="submit" class="btn btn-danger">
            <i class="fas fa-trash"></i> Delete Permanently
        </button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>