@model IEnumerable<PurchaseOrder>
@{
    ViewData["Title"] = "Purchase Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="fas fa-file-invoice-dollar"></i> @ViewData["Title"]</h2>
    @* Optional: Uncomment if you want manual PO creation *@
    @* 
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Create New Purchase Order
    </a> 
    *@
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <!-- Responsive table wrapper -->
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>PO #</th>
                        <th>Requisition #</th>
                        <th>Supplier</th>
                        <th>Created By</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-end">Total Amount</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.PONumber</td>
                            <td>@item.Requisition?.RequisitionNumber</td>
                            <td>@item.Supplier?.Name</td>
                            <td>@item.CreatedBy?.FirstName @item.CreatedBy?.LastName</td>
                            <td>@item.CreatedDate.ToString("dd-MMM-yyyy")</td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(item.Status)">
                                    @item.Status
                                </span>
                            </td>
                            <td class="text-end">
                                @item.TotalAmount.ToString("C")
                            </td>
                            <td class="text-center">
                                <!-- Details button -->
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info me-1">
                                    <i class="fas fa-eye"></i> Details
                                </a>

                                <!-- Approve button -->
                                @if (item.Status == PurchaseOrderStatus.Pending)
                                {
                                    <form asp-action="Approve" asp-route-id="@item.Id"
                                          method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-success me-1">
                                            <i class="fas fa-check"></i> Approve
                                        </button>
                                    </form>
                                }

                                <!-- Receive Goods button -->
                                @if (item.Status == PurchaseOrderStatus.Approved ||
                                                            item.Status == PurchaseOrderStatus.PartiallyReceived)
                                {
                                    <a asp-controller="GRN" asp-action="Create"
                                       asp-route-purchaseOrderId="@item.Id"
                                       class="btn btn-sm btn-primary">
                                        <i class="fas fa-truck-loading"></i> Receive
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@functions {
    private string GetStatusBadgeClass(PurchaseOrderStatus status)
    {
        return status switch
        {


            PurchaseOrderStatus.Pending => "badge-warning",
            PurchaseOrderStatus.Approved => "badge-info",
            PurchaseOrderStatus.Ordered => "badge-primary",
            PurchaseOrderStatus.PartiallyReceived => "badge-warning",
            PurchaseOrderStatus.Completed => "badge-success",
            PurchaseOrderStatus.Cancelled => "badge-danger",
            _ => "badge-secondary"
        };
    }
}
