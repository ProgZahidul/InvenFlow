@model PurchaseOrder
@{
    ViewData["Title"] = "Purchase Order Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="fas fa-file-invoice-dollar"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4 class="card-title">Purchase Order Information</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">PO #:</dt>
                    <dd class="col-sm-8">@Model.PONumber</dd>

                    <dt class="col-sm-4">Requisition #:</dt>
                    <dd class="col-sm-8">@Model.Requisition?.RequisitionNumber</dd>

                    <dt class="col-sm-4">Supplier:</dt>
                    <dd class="col-sm-8">@Model.Supplier?.Name</dd>

                    <dt class="col-sm-4">Created By:</dt>
                    <dd class="col-sm-8">@Model.CreatedBy?.FirstName @Model.CreatedBy?.LastName</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Created Date:</dt>
                    <dd class="col-sm-8">@Model.CreatedDate.ToString("dd-MMM-yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Expected Delivery:</dt>
                    <dd class="col-sm-8">@Model.ExpectedDeliveryDate?.ToString("dd-MMM-yyyy")</dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        <span class="badge @GetStatusBadgeClass(Model.Status)">
                            @Model.Status
                        </span>
                    </dd>

                    <dt class="col-sm-4">Total Amount:</dt>
                    <dd class="col-sm-8">@Model.TotalAmount.ToString("C")</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.StatusNotes))
        {
            <div class="row">
                <div class="col-md-12">
                    <dt>Status Notes:</dt>
                    <dd>@Model.StatusNotes</dd>
                </div>
            </div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header bg-secondary text-white">
        <h4 class="card-title">Items</h4>
    </div>
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Quantity</th>
                    <th>Unit Price</th>
                    <th>Total</th>
                    <th>Received</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.PurchaseOrderItems)
                {
                    var received = item.GRNItems?.Sum(gi => gi.QuantityReceived) ?? 0;
                    <tr>
                        <td>@item.Item?.Name</td>
                        <td>@item.QuantityOrdered</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@((item.QuantityOrdered * item.UnitPrice).ToString("C"))</td>
                        <td>
                            <span class="@(received >= item.QuantityOrdered ? "text-success" : "text-warning")">
                                @received / @item.QuantityOrdered
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-info">
                    <td colspan="3" class="text-right"><strong>Grand Total:</strong></td>
                    <td><strong>@Model.TotalAmount.ToString("C")</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@if (Model.GoodsReceivedNotes.Any())
{
    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h4 class="card-title">Goods Receipt History</h4>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>GRN #</th>
                        <th>Received Date</th>
                        <th>Received By</th>
                        <th>Total Items</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grn in Model.GoodsReceivedNotes)
                    {
                        <tr>
                            <td>
                                <a asp-controller="GRN" asp-action="Details" asp-route-id="@grn.Id">
                                    @grn.GRNNumber
                                </a>
                            </td>
                            <td>@grn.ReceivedDate.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td>@grn.ReceivedBy?.FirstName @grn.ReceivedBy?.LastName</td>
                            <td>@grn.GRNItems.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@functions {
    private string GetStatusBadgeClass(PurchaseOrderStatus status)
    {
        return status switch
        {
            PurchaseOrderStatus.Pending => "badge-warning",
            PurchaseOrderStatus.Approved => "badge-info",
            PurchaseOrderStatus.Ordered => "badge-primary",
            PurchaseOrderStatus.PartiallyReceived => "badge-warning",
            PurchaseOrderStatus.Completed => "badge-success",
            PurchaseOrderStatus.Cancelled => "badge-danger",
            _ => "badge-secondary"
        };
    }
}