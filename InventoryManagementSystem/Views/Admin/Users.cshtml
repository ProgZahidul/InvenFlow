@model IEnumerable<UserRoleViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
    <h2><i class="fas fa-users-cog"></i> @ViewData["Title"]</h2>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> No users found.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Roles</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.User.FirstName @item.User.LastName</td>
                                <td>@item.User.Email</td>
                                <td>@item.User.Department?.Name </td>
                                <td>
                                    @if (item.Roles != null && item.Roles.Any())
                                    {
                                        @foreach (var role in item.Roles)
                                        {
                                            <span class="badge bg-primary me-1">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Roles</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditUser" asp-route-id="@item.User.Id" class="btn btn-sm btn-info">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
