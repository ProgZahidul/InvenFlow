@model IEnumerable<Stock>
@{
    ViewData["Title"] = "Stock Inventory";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
    <h2><i class="fas fa-boxes"></i> @ViewData["Title"]</h2>
</div>

<div class="card">
    <div class="card-body table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>Item</th>
                    <th>Batch Number</th>
                    <th>Expiry Date</th>
                    <th>Quantity</th>
                    <th>Available</th>
                    <th>Unit Cost</th>
                    <th>Last Updated</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var rowClass = item.AvailableQuantity <= 0 ? "table-danger" :
                    item.ExpiryDate.HasValue && item.ExpiryDate.Value < DateTime.Now.AddDays(30) ? "table-warning" : "";

                    <tr class="@rowClass">
                        <td>@item.Item?.Name</td>
                        <td>@item.BatchNumber</td>
                        <td>@item.ExpiryDate?.ToString("dd-MMM-yyyy")</td>
                        <td>@item.Quantity</td>
                        <td>@item.AvailableQuantity</td>
                        <td>@item.UnitCost.ToString("C")</td>
                        <td>@item.LastUpdated.ToString("dd-MMM-yyyy")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info mb-1">
                                <i class="fas fa-eye"></i> Details
                            </a>
                            @if (User.IsInRole("Administrator") || User.IsInRole("InventoryManager"))
                            {
                                <a asp-action="Adjust" asp-route-id="@item.Id" class="btn btn-sm btn-warning mb-1">
                                    <i class="fas fa-adjust"></i> Adjust
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="alert alert-info mt-3">
    <i class="fas fa-info-circle"></i>
    <strong>Legend:</strong>
    <span class="text-danger">Red - Out of stock</span> |
    <span class="text-warning">Yellow - Expiring soon (less than 30 days) or low stock</span>
</div>
