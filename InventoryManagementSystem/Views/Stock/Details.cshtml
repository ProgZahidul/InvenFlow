@model Stock
@{
    ViewData["Title"] = "Stock Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="fas fa-box"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4 class="card-title">Stock Information</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Item:</dt>
                    <dd class="col-sm-8">@Model.Item?.Name</dd>

                    <dt class="col-sm-4">Batch Number:</dt>
                    <dd class="col-sm-8">@Model.BatchNumber</dd>

                    <dt class="col-sm-4">Expiry Date:</dt>
                    <dd class="col-sm-8">@Model.ExpiryDate?.ToString("dd-MMM-yyyy")</dd>

                    <dt class="col-sm-4">Unit Cost:</dt>
                    <dd class="col-sm-8">@Model.UnitCost.ToString("C")</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Total Quantity:</dt>
                    <dd class="col-sm-8">@Model.Quantity</dd>

                    <dt class="col-sm-4">Reserved Quantity:</dt>
                    <dd class="col-sm-8">@Model.ReservedQuantity</dd>

                    <dt class="col-sm-4">Available Quantity:</dt>
                    <dd class="col-sm-8">
                        <span class="@(Model.AvailableQuantity <= 0 ? "text-danger" : "text-success")">
                            @Model.AvailableQuantity
                        </span>
                    </dd>

                    <dt class="col-sm-4">Last Updated:</dt>
                    <dd class="col-sm-8">@Model.LastUpdated.ToString("dd-MMM-yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header bg-info text-white">
        <h4 class="card-title">Source Information</h4>
    </div>
    <div class="card-body">
        @if (Model.GRNItem != null && Model.GRNItem.GoodsReceivedNote != null)
        {
            <dl class="row">
                <dt class="col-sm-3">GRN #:</dt>
                <dd class="col-sm-9">
                    <a asp-controller="GoodsReceivedNote" asp-action="Details" asp-route-id="@Model.GRNItem.GRNId">
                        @Model.GRNItem.GoodsReceivedNote?.GRNNumber
                    </a>
                </dd>

                <dt class="col-sm-3">Received Date:</dt>
                <dd class="col-sm-9">@Model.GRNItem.GoodsReceivedNote?.ReceivedDate.ToString("dd-MMM-yyyy")</dd>

                <dt class="col-sm-3">PO #:</dt>
                <dd class="col-sm-9">@Model.GRNItem.GoodsReceivedNote?.PurchaseOrder?.PONumber</dd>

                <dt class="col-sm-3">Supplier:</dt>
                <dd class="col-sm-9">@Model.GRNItem.GoodsReceivedNote?.PurchaseOrder?.Supplier?.Name</dd>
            </dl>
        }

    </div>
</div>