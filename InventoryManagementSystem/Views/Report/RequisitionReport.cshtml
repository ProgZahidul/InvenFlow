@model IEnumerable<Requisition>
@{
    ViewData["Title"] = "Requisition Report";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
    <h2><i class="fas fa-clipboard-list"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary mt-2 mt-md-0">
        <i class="fas fa-arrow-left"></i> Back to Reports
    </a>
</div>

<!-- Filter Form -->
<form asp-action="RequisitionReport" method="get" class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3 col-sm-6">
                <label for="status" class="form-label">Status:</label>
               @*  <select name="status" class="form-select">
                    <option value="">-- All Statuses --</option>
                    @foreach (var status in Enum.GetValues(typeof(RequisitionStatus)))
                    {
                        <option value="@status" selected="@(ViewBag.Status?.ToString() == status.ToString())">@status</option>
                    }
                </select> *@
                <select name="status" class="form-select">
                    <option value="">-- All Statuses --</option>

                    @foreach (RequisitionStatus status in Enum.GetValues(typeof(RequisitionStatus)))
                    {
                        if (ViewBag.Status?.ToString() == status.ToString())
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3 col-sm-6">
                <label for="fromDate" class="form-label">From Date:</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
            </div>
            <div class="col-md-3 col-sm-6">
                <label for="toDate" class="form-label">To Date:</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
            </div>
            <div class="col-md-3 col-sm-6 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter"></i> Filter
                </button>
            </div>
        </div>
    </div>
</form>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> No requisitions found for the selected criteria.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Requisition #</th>
                            <th>Title</th>
                            <th>Department</th>
                            <th>Requested By</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-end">Items</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RequisitionNumber</td>
                                <td>@item.Title</td>
                                <td>@(item.Department?.Name ?? "N/A")</td>
                                <td>@(item.RequestedBy?.FirstName ?? "N/A") @(item.RequestedBy?.LastName ?? "")</td>
                                <td>@item.RequestedDate.ToString("dd-MMM-yyyy")</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(item.Status)">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end">@item.RequisitionItems?.Count ?? 0</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@functions {
    private string GetStatusBadgeClass(RequisitionStatus status)
    {
        return status switch
        {
            RequisitionStatus.Pending => "bg-warning text-dark",
            RequisitionStatus.Approved => "bg-success",
            RequisitionStatus.Rejected => "bg-danger",
            RequisitionStatus.PartiallyFulfilled => "bg-info text-dark",
            RequisitionStatus.Completed => "bg-secondary",
            _ => "bg-secondary"
        };
    }
}
