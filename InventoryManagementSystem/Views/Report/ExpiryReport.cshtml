@model IEnumerable<ExpiryReportViewModel>
@{
    ViewData["Title"] = "Expiry Report";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="fas fa-calendar-times"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to Reports
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Item</th>
                        <th>Batch Number</th>
                        <th>Expiry Date</th>
                        <th class="text-end">Days Until Expiry</th>
                        <th class="text-end">Quantity</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var rowClass = item.DaysUntilExpiry <= 0 ? "table-danger" :
                        item.DaysUntilExpiry <= 30 ? "table-warning" : "";

                        <tr class="@rowClass">
                            <td>@item.ItemName</td>
                            <td>@item.BatchNumber</td>
                            <td>@item.ExpiryDate.ToString("dd-MMM-yyyy")</td>
                            <td class="text-end">@item.DaysUntilExpiry</td>
                            <td class="text-end">@item.Quantity</td>
                            <td>
                                @if (item.DaysUntilExpiry <= 0)
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                                else if (item.DaysUntilExpiry <= 30)
                                {
                                    <span class="badge bg-warning text-dark">Expiring Soon</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">OK</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
