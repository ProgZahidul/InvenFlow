@model IEnumerable<TransactionReportViewModel>
@{
    ViewData["Title"] = "Transaction Report";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
    <h2><i class="fas fa-exchange-alt"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary mt-2 mt-md-0">
        <i class="fas fa-arrow-left"></i> Back to Reports
    </a>
</div>

<!-- Filter Form -->
<form asp-action="TransactionReport" method="get" class="card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4 col-sm-6">
                <label for="fromDate" class="form-label">From Date:</label>
                <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
            </div>
            <div class="col-md-4 col-sm-6">
                <label for="toDate" class="form-label">To Date:</label>
                <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
            </div>
            <div class="col-md-4 col-sm-6 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter"></i> Filter
                </button>
            </div>
        </div>
    </div>
</form>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> No transactions found for the selected criteria.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Item</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Cost</th>
                            <th class="text-end">Total Cost</th>
                            <th>Reference</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Date.ToString("dd-MMM-yyyy")</td>
                                <td>
                                    <span class="badge @(item.Type == "Receipt" ? "bg-success" : "bg-info text-dark")">
                                        @item.Type
                                    </span>
                                </td>
                                <td>@item.ItemName</td>
                                <td class="text-end">@item.Quantity</td>
                                <td class="text-end">@item.UnitCost.ToString("C")</td>
                                <td class="text-end">@item.TotalCost.ToString("C")</td>
                                <td>@item.Reference</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-info">
                            <td colspan="5" class="text-end"><strong>Grand Total:</strong></td>
                            <td class="text-end"><strong>@Model.Sum(t => t.TotalCost).ToString("C")</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}
