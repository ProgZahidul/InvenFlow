@model IEnumerable<Requisition>
@{
    ViewData["Title"] = "Purchase Requisitions";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="fas fa-clipboard-list"></i> @ViewData["Title"]</h2>
    @if (User.IsInRole("DepartmentUser"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Create New
        </a>
    }
</div>

<!-- Alerts -->
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Requisitions Table -->
<div class="card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle"></i> No requisitions found.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Requisition #</th>
                            <th>Title</th>
                            <th>Department</th>
                            <th>Requested By</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RequisitionNumber</td>
                                <td>@item.Title</td>
                                <td>@item.Department?.Name</td>
                                <td>@item.RequestedBy?.FirstName @item.RequestedBy?.LastName</td>
                                <td>@item.RequestedDate.ToString("dd-MMM-yyyy")</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(item.Status)">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <!-- Details button -->
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <!-- Review button for pending requisitions -->
                                        @if ((User.IsInRole("Administrator") || User.IsInRole("InventoryManager") || User.IsInRole("Approver")) && item.Status == RequisitionStatus.Pending)
                                        {
                                            <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success" title="Review">
                                                <i class="fas fa-check"></i>
                                            </a>
                                        }

                                        <!-- Create PO button for approved requisitions -->
                                        @if ((User.IsInRole("Administrator") || User.IsInRole("InventoryManager") || User.IsInRole("Approver")) && item.Status == RequisitionStatus.Approved)
                                        {
                                            <a asp-controller="PurchaseOrder"
                                               asp-action="Create"
                                               asp-route-requisitionId="@item.Id"
                                               class="btn btn-sm btn-primary" title="Create PO">
                                                <i class="fas fa-file-invoice-dollar"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private string GetStatusBadgeClass(RequisitionStatus status)
    {
        return status switch
        {
            RequisitionStatus.Pending => "bg-warning text-dark",
            RequisitionStatus.Approved => "bg-success",
            RequisitionStatus.Rejected => "bg-danger",
            RequisitionStatus.PartiallyFulfilled => "bg-info text-dark",
            RequisitionStatus.Completed => "bg-secondary",
            _ => "bg-secondary"
        };
    }
}
