@model Requisition
@{
    ViewData["Title"] = "Requisition Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="fas fa-clipboard-list"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4 class="card-title">Requisition Information</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Requisition #:</dt>
                    <dd class="col-sm-8">@Model.RequisitionNumber</dd>

                    <dt class="col-sm-4">Title:</dt>
                    <dd class="col-sm-8">@Model.Title</dd>

                    <dt class="col-sm-4">Department:</dt>
                    <dd class="col-sm-8">@Model.Department?.Name</dd>

                    <dt class="col-sm-4">Requested By:</dt>
                    <dd class="col-sm-8">@Model.RequestedBy?.FirstName @Model.RequestedBy?.LastName</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Requested Date:</dt>
                    <dd class="col-sm-8">@Model.RequestedDate.ToString("dd-MMM-yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        <span class=" @GetStatusBadgeClass(Model.Status)">
                            @Model.Status
                        </span>
                    </dd>

                    @if (Model.ApprovedBy != null)
                    {
                        <dt class="col-sm-4">Approved By:</dt>
                        <dd class="col-sm-8">@Model.ApprovedBy?.FirstName @Model.ApprovedBy?.LastName</dd>

                        <dt class="col-sm-4">Approved Date:</dt>
                        <dd class="col-sm-8">@Model.ApprovedDate?.ToString("dd-MMM-yyyy HH:mm")</dd>
                    }
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="row">
                <div class="col-md-12">
                    <dt>Description:</dt>
                    <dd>@Model.Description</dd>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.StatusNotes))
        {
            <div class="row">
                <div class="col-md-12">
                    <dt>Status Notes:</dt>
                    <dd>@Model.StatusNotes</dd>
                </div>
            </div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header bg-secondary text-white">
        <h4 class="card-title">Items</h4>
    </div>
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Quantity</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.RequisitionItems)
                {
                    <tr>
                        <td>@item.Item?.Name</td>
                        <td>@item.Quantity</td>
                        <td>@item.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (User.IsInRole("Administrator") || User.IsInRole("InventoryManager"))
{
    @if (Model.Status == RequisitionStatus.Pending)
    {
        <div class="card mt-3">
            <div class="card-header bg-warning text-white">
                <h4 class="card-title">Approval Actions</h4>
            </div>
            <div class="card-body">
                <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <div class="form-group">
                        <label for="statusNotes">Approval Notes:</label>
                        <textarea name="statusNotes" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check"></i> Approve
                    </button>
                </form>

                <form asp-action="Reject" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <div class="form-group">
                        <label for="statusNotes">Rejection Notes:</label>
                        <textarea name="statusNotes" class="form-control" rows="3"></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-times"></i> Reject
                    </button>
                </form>
            </div>
        </div>
    }
}

@functions {
    private string GetStatusBadgeClass(RequisitionStatus status)
    {
        return status switch
        {
            RequisitionStatus.Pending => "badge-warning",
            RequisitionStatus.Approved => "badge-success",
            RequisitionStatus.Rejected => "badge-danger",
            RequisitionStatus.PartiallyFulfilled => "badge-info",
            RequisitionStatus.Completed => "badge-secondary",
            _ => "badge-secondary"
        };
    }
}