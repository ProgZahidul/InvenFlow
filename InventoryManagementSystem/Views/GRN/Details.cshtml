@model GoodsReceivedNote
@{
    ViewData["Title"] = "GRN Details";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
    <h2><i class="fas fa-truck-loading"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary mt-2 mt-md-0">Back to List</a>
</div>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4 class="card-title">GRN Information</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6 mb-3 mb-md-0">
                <dl class="row">
                    <dt class="col-4">GRN #:</dt>
                    <dd class="col-8">@Model.GRNNumber</dd>

                    <dt class="col-4">PO #:</dt>
                    <dd class="col-8">@Model.PurchaseOrder?.PONumber</dd>

                    <dt class="col-4">Supplier:</dt>
                    <dd class="col-8">@Model.PurchaseOrder?.Supplier?.Name</dd>

                    <dt class="col-4">Received By:</dt>
                    <dd class="col-8">@Model.ReceivedBy?.FirstName @Model.ReceivedBy?.LastName</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-4">Received Date:</dt>
                    <dd class="col-8">@Model.ReceivedDate.ToString("dd-MMM-yyyy HH:mm")</dd>

                    <dt class="col-4">Total Items:</dt>
                    <dd class="col-8">@Model.GRNItems.Count</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="row mt-2">
                <div class="col-12">
                    <dt>Notes:</dt>
                    <dd>@Model.Notes</dd>
                </div>
            </div>
        }
    </div>
</div>

<div class="card mt-3">
    <div class="card-header bg-secondary text-white">
        <h4 class="card-title">Received Items</h4>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>Item</th>
                    <th>Quantity Received</th>
                    <th>Unit Price</th>
                    <th>Batch Number</th>
                    <th>Expiry Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.GRNItems)
                {
                    <tr>
                        <td>@item.PurchaseOrderItem?.Item?.Name</td>
                        <td>@item.QuantityReceived</td>
                        <td>@item.UnitCost.ToString("C")</td>
                        <td>@item.BatchNumber</td>
                        <td>@item.ExpiryDate?.ToString("dd-MMM-yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
