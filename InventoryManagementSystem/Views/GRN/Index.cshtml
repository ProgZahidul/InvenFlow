@model IEnumerable<GoodsReceivedNote>
@{
    ViewData["Title"] = "Goods Received Notes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold text-primary">
        <i class="fas fa-truck-loading me-2"></i> @ViewData["Title"]
    </h2>
</div>

<div class="card shadow-lg border-0 rounded-3">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle shadow-sm">
                <thead class="table-dark text-uppercase small">
                    <tr>
                        <th>GRN #</th>
                        <th>PO #</th>
                        <th>Received By</th>
                        <th>Received Date</th>
                        <th>Total Items</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="align-middle">
                            <td class="fw-medium">@item.GRNNumber</td>
                            <td>@item.PurchaseOrder?.PONumber </td>
                            <td>@item.ReceivedBy?.FirstName @item.ReceivedBy?.LastName</td>
                            <td>@item.ReceivedDate.ToString("dd-MMM-yyyy")</td>
                            <td>@item.PurchaseOrder?.Status.ToString() </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info shadow-sm"
                                   data-bs-toggle="tooltip" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Enable Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}
