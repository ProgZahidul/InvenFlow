@model IEnumerable<Issue>
@{
    ViewData["Title"] = "Item Issues";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
    <h2><i class="fas fa-share-square"></i> @ViewData["Title"]</h2>
    @if (User.IsInRole("Administrator") || User.IsInRole("InventoryManager") || User.IsInRole("Storekeeper"))
    {
        <a asp-action="Create" class="btn btn-primary mt-2 mt-md-0">
            <i class="fas fa-plus"></i> Create New
        </a>
    }
</div>

<div class="card">
    <div class="card-body table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Issue #</th>
                    <th>Department</th>
                    <th>Requested By</th>
                    <th>Issued By</th>
                    <th>Issue Date</th>
                    <th>Total Items</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            <i class="fas fa-info-circle"></i> No issues found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IssueNumber</td>
                            <td>@item.Department?.Name</td>
                            <td>@item.RequestedBy?.FirstName @item.RequestedBy?.LastName</td>
                            <td>@item.IssuedBy?.FirstName @item.IssuedBy?.LastName</td>
                            <td>@item.IssueDate.ToString("dd-MMM-yyyy")</td>
                            <td>@item.IssueItems.Count</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> Details
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
