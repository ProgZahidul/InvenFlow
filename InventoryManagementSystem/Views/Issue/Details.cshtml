@model Issue
@{
    ViewData["Title"] = "Issue Details";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
    <h2><i class="fas fa-share-square"></i> @ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-secondary mt-2 mt-md-0">Back to List</a>
</div>

<div class="card mb-3">
    <div class="card-header bg-primary text-white">
        <h4 class="card-title">Issue Information</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Issue #:</dt>
                    <dd class="col-sm-8">@Model.IssueNumber</dd>

                    <dt class="col-sm-4">Department:</dt>
                    <dd class="col-sm-8">@Model.Department?.Name</dd>

                    <dt class="col-sm-4">Requested By:</dt>
                    <dd class="col-sm-8">@Model.RequestedBy?.FirstName @Model.RequestedBy?.LastName</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Issued By:</dt>
                    <dd class="col-sm-8">@Model.IssuedBy?.FirstName @Model.IssuedBy?.LastName</dd>

                    <dt class="col-sm-4">Issue Date:</dt>
                    <dd class="col-sm-8">@Model.IssueDate.ToString("dd-MMM-yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Total Items:</dt>
                    <dd class="col-sm-8">@Model.IssueItems?.Count</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="row mt-2">
                <div class="col-md-12">
                    <dt>Notes:</dt>
                    <dd>@Model.Notes</dd>
                </div>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header bg-secondary text-white">
        <h4 class="card-title">Issued Items</h4>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Batch Number</th>
                    <th>Quantity</th>
                    <th>Unit Cost</th>
                    <th>Total Cost</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.IssueItems == null || !Model.IssueItems.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            <i class="fas fa-info-circle"></i> No items issued.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.IssueItems)
                    {
                        var unitCost = item.Stock?.UnitCost ?? 0;
                        <tr>
                            <td>@item.Item?.Name</td>
                            <td>@item.Stock?.BatchNumber</td>
                            <td>@item.Quantity</td>
                            <td>@unitCost.ToString("C")</td>
                            <td>@(item.Quantity* unitCost)</td>
                        </tr>
                    }
                }
            </tbody>
            @if (Model.IssueItems?.Any() == true)
            {
                <tfoot>
                    <tr class="table-info">
                        <td colspan="4" class="text-right"><strong>Grand Total:</strong></td>
                        <td><strong>@Model.IssueItems.Sum(i => i.Quantity * (i.Stock?.UnitCost ?? 0)).ToString("C")</strong></td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>
